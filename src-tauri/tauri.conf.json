{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flaxia",
  "version": "0.1.0",
  "identifier": "app.flaxia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://flaxia.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Flaxia",
        "url": "https://flaxia.app",
        "width": 412,
        "height": 915,
        "resizable": false,
        "fullscreen": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
