{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flaxia",
  "version": "0.1.0",
  "identifier": "app.flaxia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://flaxia.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Flaxia",
        "url": "https://flaxia.app",
        "width": 1200,
        "height": 800,
        "minWidth": 240,
        "minHeight": 200,
        "maxWidth": 7680,
        "maxHeight": 4320,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
