{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flaxia",
  "version": "0.1.0",
  "identifier": "app.flaxia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://flaxia.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
