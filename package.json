{
  "name": "flaxia",
  "version": "0.1.0",
  "description": "Chronological SNS where posts are living, interactive applications",
  "type": "module",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "dev": "npm run migrate:local && vite build && wrangler pages dev dist --port 8787 --binding BASE_URL=http://localhost:8787 --binding SANDBOX_ORIGIN=http://localhost:3000 --do NOTIFICATION_STREAM=NotificationStream@do-worker",
    "dev:hot": "npm run migrate:local && (trap 'kill 0 2>/dev/null' EXIT; vite build --watch & wrangler pages dev dist --port 8787 --binding BASE_URL=http://localhost:8787 --binding SANDBOX_ORIGIN=http://localhost:3000 --do NOTIFICATION_STREAM=NotificationStream@do-worker & wait)",
    "dev:api": "npm run migrate:local && wrangler pages dev dist --port 8787 --binding BASE_URL=http://localhost:8787 --binding SANDBOX_ORIGIN=http://localhost:3000 --do NOTIFICATION_STREAM=NotificationStream@do-worker",
    "dev:local": "vite --host",
    "dev:all": "npm run migrate:local && rm -rf dist && mkdir dist && (trap 'kill 0 2>/dev/null' EXIT; vite --host & wrangler pages dev dist --port 8787 --binding BASE_URL=http://localhost:8787 --binding SANDBOX_ORIGIN=http://localhost:3000 --do NOTIFICATION_STREAM=NotificationStream@do-worker & wait)",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "CONTENT_ORIGIN=https://sandbox.flaxia.app wrangler pages deploy dist",
    "deploy:sandbox": "wrangler deploy src/sandbox-worker.ts --config wrangler.sandbox.toml",
    "deploy:do": "wrangler deploy --config do-worker/wrangler.toml",
    "dev:do": "wrangler dev --config do-worker/wrangler.toml --port 8789",
    "setup": "npm install && npm run migrate:local",
    "migrate:local": "wrangler d1 migrations apply flaxia --local",
    "migrate:prod": "wrangler d1 migrations apply flaxia",
    "test": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:auth": "node --test --experimental-strip-types tests/auth.test.ts",
    "test:posts": "node --test --experimental-strip-types tests/posts.test.ts",
    "test:users": "node --test --experimental-strip-types tests/users.test.ts",
    "test:notifications": "node --test --experimental-strip-types tests/notifications.test.ts",
    "test:tags": "node --test --experimental-strip-types tests/tags.test.ts",
    "test:rate-limit": "node --test --experimental-strip-types tests/rate-limit.test.ts",
    "dev:test": "wrangler pages dev dist --d1=DB_TEST --kv=RATE_LIMIT_TEST --port 8788 --binding BASE_URL=http://localhost:8788 --do NOTIFICATION_STREAM=NotificationStream@do-worker",
    "tauri": "tauri",
    "tauri:dev": "node scripts/merge-tauri-config.mjs && tauri dev",
    "tauri:build": "node scripts/merge-tauri-config.mjs && tauri build",
    "tauri:dev:windows": "TAURI_TARGET_PLATFORM=windows node scripts/merge-tauri-config.mjs && tauri dev",
    "tauri:build:windows": "TAURI_TARGET_PLATFORM=windows node scripts/merge-tauri-config.mjs && tauri build",
    "tauri:dev:macos": "TAURI_TARGET_PLATFORM=macos node scripts/merge-tauri-config.mjs && tauri dev",
    "tauri:build:macos": "TAURI_TARGET_PLATFORM=macos node scripts/merge-tauri-config.mjs && tauri build",
    "tauri:dev:linux": "TAURI_TARGET_PLATFORM=linux node scripts/merge-tauri-config.mjs && tauri dev",
    "tauri:build:linux": "TAURI_TARGET_PLATFORM=linux node scripts/merge-tauri-config.mjs && tauri build",
    "cap:init": "npx cap init Flaxia app.flaxia.app",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build:android": "npx cap sync && npx cap copy && cd android && ./gradlew assembleDebug",
    "cap:build:ios": "npx cap sync && npx cap copy",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capawesome/capacitor-badge": "^8.0.2",
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@flaxia/node": "^0.1.2",
    "@flaxia/sdk": "^0.1.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "better-auth": "^1.5.4",
    "dompurify": "^3.0.0",
    "fflate": "^0.8.2",
    "hono": "^4.0.0",
    "imagesize": "^1.0.0",
    "js-dos": "^8.3.20",
    "jszip": "^3.10.1",
    "katex": "^0.16.0",
    "lucide": "^0.300.0",
    "markdown-it": "^14.0.0",
    "nanoid": "^5.1.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@capacitor/cli": "^8.3.4",
    "@cloudflare/workers-types": "^4.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^3.3.0",
    "wrangler": "^4.73.0"
  },
  "packageManager": "pnpm@8.0.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,html,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
